# Host identity — container files will be owned by this UID/GID.
# Populate with: id -u, id -g, echo $USER
HOST_UID=1000
HOST_GID=1000
USER=yourname

# Compose project namespace. Controls image/container/volume naming:
#   <COMPOSE_PROJECT_NAME>-base:latest
#   <COMPOSE_PROJECT_NAME>-<VARIANT>:latest
COMPOSE_PROJECT_NAME=agent-sandbox

# Active variant — uncomment exactly ONE.
VARIANT=python-uv
# VARIANT=python-poetry
# VARIANT=php
# VARIANT=minimal

# Language versions (used only by the matching variant).
PYTHON_VERSION="3.10 3.11 3.12"
# PHP_VERSION=8.4
